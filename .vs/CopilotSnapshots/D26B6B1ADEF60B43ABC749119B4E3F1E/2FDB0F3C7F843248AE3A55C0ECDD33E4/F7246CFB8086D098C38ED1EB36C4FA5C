@namespace RandomDraw.Pages
@inject ExcelService Excel
@inject IJSRuntime JS
@implements IDisposable

<div class="app-container">
    @* ===== Header with file upload ===== *@
    <div class="app-header">
        <h1>&#x1F3B2; Random Draw</h1>
        <div class="upload-area">
            <label>
                &#x1F4C2; Load Excel File
                <InputFile OnChange="OnFileSelected" accept=".xlsx" style="display:none" />
            </label>
            @if (Excel.IsLoaded)
            {
                <span class="file-name">&#x2705; @Excel.FileName</span>
            }
        </div>
    </div>

    @* ===== Draw Data Grid ===== *@
    <div class="grid-section" style="flex:2">
        <h3>Draw Data</h3>
        <div class="grid-wrapper">
            @if (drawTable.Columns.Count > 0 && drawTable.Rows.Count > 0)
            {
                <table class="data-grid">
                    <thead>
                        <tr>
                            @foreach (System.Data.DataColumn col in drawTable.Columns)
                            {
                                <th>@col.ColumnName</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (System.Data.DataRow row in drawTable.Rows)
                        {
                            <tr>
                                @foreach (System.Data.DataColumn col in drawTable.Columns)
                                {
                                    <td>@(row[col]?.ToString())</td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-message">Upload an Excel file (.xlsx) to get started</div>
            }
        </div>
    </div>

    @* ===== Winners Grid ===== *@
    <div class="grid-section" style="flex:1">
        <h3>Winners</h3>
        <div class="grid-wrapper">
            @if (winnersTable.Columns.Count > 0 && winnersTable.Rows.Count > 0)
            {
                <table class="data-grid">
                    <thead>
                        <tr>
                            @foreach (System.Data.DataColumn col in winnersTable.Columns)
                            {
                                <th>@col.ColumnName</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (System.Data.DataRow row in winnersTable.Rows)
                        {
                            <tr>
                                @foreach (System.Data.DataColumn col in winnersTable.Columns)
                                {
                                    <td>@(row[col]?.ToString())</td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-message">No winners yet</div>
            }
        </div>
    </div>

    @* ===== Reel Display and Progress ===== *@
    <div class="reel-area">
        <div class="reels">
            @for (int i = 0; i < 5; i++)
            {
                <div class="reel-digit @(isSpinning ? "spinning" : "")">@reelDigits[i]</div>
            }
        </div>

        @if (progressTotal > 0)
        {
            <div class="progress-area">
                <div class="progress-bar-container">
                    <div class="progress-bar-fill" style="width: @(progressTotal > 0 ? (int)(100.0 * progressCurrent / progressTotal) : 0)%"></div>
                </div>
                <span class="progress-text">@progressMessage</span>
            </div>
        }
    </div>

    @* ===== Controls Bar ===== *@
    <div class="controls-bar">
        <div class="region-selector">
            <label>Region:</label>
            <select @bind="selectedRegion" @bind:after="OnRegionChanged" disabled="@(!Excel.IsLoaded)">
                <option value="">All Regions</option>
                @foreach (var r in regions)
                {
                    <option value="@r">@r</option>
                }
            </select>
        </div>

        <button class="btn btn-clear" @onclick="ClearWinners" disabled="@(!Excel.IsLoaded)">1. Clear Winners</button>
        <button class="btn btn-assign" @onclick="AssignRandomNumbers" disabled="@(!Excel.IsLoaded || isAssigning)">2. Assign Random Numbers</button>
        <button class="btn btn-start" @onclick="StartGenerator" disabled="@(!Excel.IsLoaded || isSpinning)">3. Start Generator</button>
        <button class="btn btn-pick" @onclick="PickWinner" disabled="@(!isSpinning)">4. Pick Winner</button>
        <button class="btn btn-print" @onclick="PrintWinners" disabled="@(winnersTable.Rows.Count == 0)">5. Print Winners</button>
    </div>
</div>

@* ===== Loading Overlay ===== *@
@if (isLoadingFile)
{
    <div class="loading-overlay">
        <div class="loading-card">
            <div class="spinner"></div>
            <h3>Loading Excel File</h3>
            <p>@loadingStatus</p>
        </div>
    </div>
}

@* ===== Alert Modal ===== *@
@if (alertMessage != null)
{
    <div class="alert-overlay" @onclick="DismissAlert">
        <div class="alert-box" @onclick:stopPropagation>
            <h3>@alertTitle</h3>
            <p>@alertMessage</p>
            <button class="btn btn-assign" @onclick="DismissAlert">OK</button>
        </div>
    </div>
}

@* ===== Winner Highlight Modal ===== *@
@if (showWinnerCard)
{
    <div class="winner-highlight" @onclick="DismissWinner">
        <div class="winner-card" @onclick:stopPropagation>
            <h2>&#x1F3C6; Winner!</h2>
            <div class="winner-name">@winnerName</div>
            <div class="winner-details">Employee: @winnerEmplNo</div>
            <div class="winner-details">Region: @winnerRegion &bull; ID: @winnerId &bull; Draw #: @winnerRandomId</div>
            <button class="btn" @onclick="DismissWinner">Close</button>
        </div>
    </div>
}

@code {
    // Data
    private System.Data.DataTable drawTable = new("Draw");
    private System.Data.DataTable winnersTable = new("Winners");
    private List<string> regions = new();
    private string selectedRegion = "";

    // Reel state
    private string[] reelDigits = { "0", "0", "0", "0", "0" };
    private bool isSpinning;
    private System.Threading.Timer? spinTimer;
    private readonly Random rng = new();

    // Progress
    private int progressCurrent;
    private int progressTotal;
    private string progressMessage = "";
    private bool isAssigning;

    // File loading
    private bool isLoadingFile;
    private string loadingStatus = "";

    // Alerts
    private string? alertTitle;
    private string? alertMessage;

    // Winner display
    private bool showWinnerCard;
    private string winnerName = "";
    private string winnerEmplNo = "";
    private string winnerRegion = "";
    private int winnerId;
    private int winnerRandomId;

    // ===== File Upload =====
    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        isLoadingFile = true;
        loadingStatus = $"Reading {file.Name}...";
        StateHasChanged();
        await Task.Delay(50); // let UI render

        using var ms = new MemoryStream();
        var stream = file.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
        var buffer = new byte[81920];
        long totalRead = 0;
        int bytesRead;
        while ((bytesRead = await stream.ReadAsync(buffer)) > 0)
        {
            ms.Write(buffer, 0, bytesRead);
            totalRead += bytesRead;
            loadingStatus = $"Reading {file.Name}... ({totalRead / 1024:N0} KB)";
            StateHasChanged();
            await Task.Delay(1); // yield to UI
        }
        var bytes = ms.ToArray();

        loadingStatus = "Validating and preparing workbook...";
        StateHasChanged();
        await Task.Delay(50);

        var error = Excel.LoadFromBytes(bytes, file.Name);
        if (error != null)
        {
            isLoadingFile = false;
            ShowAlert("Error", error);
            return;
        }

        loadingStatus = "Loading data...";
        StateHasChanged();
        await Task.Delay(50);

        RefreshDrawGrid();
        RefreshWinnersGrid();

        regions = Excel.GetDistinctRegions();
        selectedRegion = "";

        isLoadingFile = false;
    }

    // ===== Grid Refresh =====
    private void RefreshDrawGrid()
    {
        drawTable = string.IsNullOrEmpty(selectedRegion)
            ? Excel.LoadDrawData()
            : Excel.LoadDrawDataByRegion(selectedRegion);
    }

    private void RefreshWinnersGrid()
    {
        winnersTable = Excel.LoadWinnersData();
    }

    // ===== Region Changed =====
    private void OnRegionChanged()
    {
        RefreshDrawGrid();
    }

    // ===== 1. Clear Winners =====
    private void ClearWinners()
    {
        Excel.ClearWinners();
        RefreshWinnersGrid();
    }

    // ===== 2. Assign Random Numbers =====
    private async Task AssignRandomNumbers()
    {
        isAssigning = true;

        // Clear old values
        if (string.IsNullOrEmpty(selectedRegion))
            Excel.ClearRandomIDs();
        else
            Excel.ClearRandomIDsByRegion(selectedRegion);

        RefreshDrawGrid();

        progressTotal = drawTable.Rows.Count;
        progressCurrent = 0;
        progressMessage = $"0 of {progressTotal}";
        StateHasChanged();

        // Small delay so UI renders before heavy work
        await Task.Delay(50);

        try
        {
            var pairs = Excel.AssignRandomIDs(drawTable);

            // Animate progress
            foreach (var pair in pairs)
            {
                progressCurrent++;
                string rndStr = pair.Rnd.ToString().PadLeft(5, '0');
                for (int i = 0; i < 5; i++)
                    reelDigits[i] = rndStr[i].ToString();

                progressMessage = $"Record {progressCurrent} of {progressTotal}";

                // Yield to UI periodically
                if (progressCurrent % 50 == 0 || progressCurrent == progressTotal)
                {
                    StateHasChanged();
                    await Task.Delay(1);
                }
            }
        }
        catch (Exception ex)
        {
            ShowAlert("Error", "An error occurred during update: " + ex.Message);
        }

        progressMessage = "DONE";
        RefreshDrawGrid();
        isAssigning = false;
        StateHasChanged();
    }

    // ===== 3. Start Number Generator =====
    private void StartGenerator()
    {
        if (drawTable.Rows.Count == 0) return;

        isSpinning = true;

        spinTimer?.Dispose();
        spinTimer = new System.Threading.Timer(async _ =>
        {
            int maxNumber = drawTable.Rows.Count;
            if (maxNumber == 0) return;

            int currentNumber = rng.Next(maxNumber);
            string numberString = currentNumber.ToString().PadLeft(5, '0');

            for (int i = 0; i < 5; i++)
                reelDigits[i] = numberString[i].ToString();

            await InvokeAsync(StateHasChanged);
        }, null, 0, 80); // ~12.5 fps
    }

    // ===== 4. Pick Winner =====
    private void PickWinner()
    {
        // Stop spinning
        spinTimer?.Dispose();
        spinTimer = null;
        isSpinning = false;

        string fullNumber = string.Join("", reelDigits).TrimStart('0');
        if (string.IsNullOrEmpty(fullNumber)) fullNumber = "0";

        var matches = drawTable.Select("RandomID='" + fullNumber + "'");
        if (matches.Length == 0)
        {
            ShowAlert("Not Found", $"No matching record found for RandomID: {fullNumber}");
            return;
        }

        var dr = matches[0];
        winnerRegion = dr["Region"]?.ToString() ?? "";
        winnerId = Convert.ToInt32(dr["ID"]);
        winnerName = dr[Excel.FullNameColumn]?.ToString() ?? "";
        winnerEmplNo = dr[Excel.EmployeeNumberColumn]?.ToString() ?? "";
        winnerRandomId = Convert.ToInt32(fullNumber);

        Excel.InsertWinner(winnerRegion, winnerId, winnerName, winnerEmplNo, winnerRandomId);
        RefreshWinnersGrid();

        showWinnerCard = true;
    }

    // ===== 5. Print Winners =====
    private async Task PrintWinners()
    {
        if (winnersTable.Rows.Count == 0)
        {
            ShowAlert("Print Winners", "No winners to print.");
            return;
        }

        var html = Excel.GenerateWinnersHtml(winnersTable);
        await JS.InvokeVoidAsync("printHtml", html);
    }

    // ===== Alerts =====
    private void ShowAlert(string title, string message)
    {
        alertTitle = title;
        alertMessage = message;
    }

    private void DismissAlert()
    {
        alertTitle = null;
        alertMessage = null;
    }

    private void DismissWinner()
    {
        showWinnerCard = false;
    }

    public void Dispose()
    {
        spinTimer?.Dispose();
    }
}
